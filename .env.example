# Google OAuth Client ID
# Required to enable Google Sign-In and Google Drive sync.
# Leave empty to run the app in offline-only mode (no login, no cloud sync).
VITE_GOOGLE_CLIENT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Ludopedia OAuth backend (Node BFF)
# Official flow: authorize with app_id + redirect_uri, then tokenrequest with code.
LUDOPEDIA_APP_ID=
LUDOPEDIA_REDIRECT_URI=http://localhost:8787/api/ludopedia/oauth/callback
LUDOPEDIA_FRONTEND_RETURN_URL=http://localhost:5173
LUDOPEDIA_SESSION_SECRET=
MEEPLEMIND_ALLOWED_ORIGINS=http://localhost:5173
LUDOPEDIA_BACKEND_PORT=8787
LUDOPEDIA_COOKIE_SECURE=0

# Optional frontend override. Recommended in localhost to avoid CSP blocks.
VITE_LUDOPEDIA_BFF_BASE=/api/ludopedia

# BGG authenticated API token (optional)
# When set, the Vite dev proxy forwards this as a Bearer token to boardgamegeek.com.
# Leave empty to use the public XML API v2 (no auth required).
BGG_ACCESS_TOKEN=